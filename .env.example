PORT=3002
NODE_ENV=development

# PostgreSQL (pgvector) — omit to use in-memory storage
DATABASE_URL=postgresql://user:password@localhost:5432/hive_civilization
SENTRY_DSN=

# HiveTrust integration
HIVETRUST_API_URL=https://hivetrust.onrender.com
HIVE_INTERNAL_KEY=

# HiveAgent integration
HIVEAGENT_API_URL=https://hiveagentiq.com

# Payment
STRIPE_SECRET_KEY=
HIVE_PAYMENT_ADDRESS=

# Embedding (optional - uses simple hash-based embeddings in dev mode)
OPENAI_API_KEY=
